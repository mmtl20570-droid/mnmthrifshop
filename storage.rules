rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Inventory and product images
    match /inventory/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default catch-all denies by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
