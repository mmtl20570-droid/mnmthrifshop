{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "MNM Thriftshop.html",
      "MNM_Thriftshop*.html",
      "mnm_thriftshop_final*.html",
      "mnm-thriftshop*.html",
      "mnm_final_site*.html",
      "mnm_grunge_progress.html",
      "index_clean.html",
      "MNM Thriftshop_files/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "X-Content-Type-Options", "value": "nosniff" }
        ]
      },
      {
        "source": "**/*.{jpg,jpeg,png,gif,webp,svg}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "robots.txt",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "sitemap.xml",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
